{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "subtitle": {
      "type": "string"
    },
    "company": {
      "type": "string"
    },
    "year": {
      "type": "number"
    },
    "role": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "heroImage": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "impact": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "featured": {
      "type": "boolean"
    },
    "visibility": {
      "default": "public",
      "type": "string",
      "enum": [
        "public",
        "password",
        "hidden"
      ]
    },
    "password": {
      "type": "string"
    },
    "order": {
      "type": "number"
    },
    "startDate": {
      "type": "string",
      "format": "date-time"
    },
    "endDate": {
      "type": "string",
      "format": "date-time"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "subtitle",
    "company",
    "year",
    "role",
    "tags",
    "heroImage",
    "summary",
    "featured",
    "order",
    "startDate"
  ]
}