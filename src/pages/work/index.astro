---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('work');
const visible = allProjects
  .filter((p) => p.data.visibility !== 'hidden')
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Work" description="Selected case studies by Mohak Gulati — product designer at Microsoft.">
  <section class="mx-auto max-w-6xl px-[var(--page-x)] py-16">
    <h1 class="text-3xl font-semibold tracking-tight text-on-surface mb-12">Work</h1>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {visible.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  </section>
</BaseLayout>
