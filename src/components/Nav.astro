---
const navLinks = [
  { label: 'Work', href: '/work' },
  { label: 'About', href: '/about' },
  { label: 'Resume', href: '/resume' },
  { label: 'Contact', href: 'mailto:mohakgulati99@gmail.com' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-border">
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between px-[var(--page-x)] py-4"
    aria-label="Main navigation"
  >
    <a href="/" class="text-sm font-medium text-on-surface hover:text-on-surface-muted transition-colors">
      Mohak Gulati
    </a>
    <ul class="flex items-center gap-6 list-none m-0 p-0">
      {navLinks.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class:list={[
              'text-sm transition-colors',
              href.startsWith('mailto')
                ? 'text-on-surface hover:text-on-surface-muted'
                : currentPath.startsWith(href)
                  ? 'text-on-surface font-medium'
                  : 'text-on-surface-muted hover:text-on-surface',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
