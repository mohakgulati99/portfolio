---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'work'>;
}

const { project } = Astro.props;
const { title, subtitle, company, year, tags, summary, visibility } = project.data;
const href = `/work/${project.id}`;
---

<article class="group border border-border rounded-lg overflow-hidden hover:border-on-surface-muted transition-colors">
  <a href={href} class="block">
    <!-- Hero image placeholder -->
    <div class="aspect-video bg-surface-overlay flex items-center justify-center">
      <span class="text-xs text-on-surface-muted">Hero image</span>
    </div>

    <div class="p-6">
      <div class="flex items-start justify-between gap-4 mb-2">
        <div>
          <h2 class="text-base font-semibold text-on-surface group-hover:underline">
            {title}
            {visibility === 'password' && (
              <span class="ml-2 text-xs font-normal text-on-surface-muted" aria-label="Password protected">
                🔒
              </span>
            )}
          </h2>
          <p class="text-sm text-on-surface-muted">{company} &middot; {year}</p>
        </div>
      </div>

      <p class="text-sm text-on-surface-muted mt-3 line-clamp-2">{summary}</p>

      <ul class="flex flex-wrap gap-2 mt-4 list-none p-0 m-0">
        {tags.map((tag) => (
          <li class="rounded-full border border-border px-3 py-0.5 text-xs text-on-surface-muted">
            {tag}
          </li>
        ))}
      </ul>
    </div>
  </a>
</article>
