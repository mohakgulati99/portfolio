---
interface Props {
  heading?: string;
  tagline?: string;
}

const {
  heading = 'Mohak Gulati',
  tagline = 'Product designer building planet-scale experiences. Currently designing agentic experiences for M365 Copilot at Microsoft.',
} = Astro.props;
---

<section class="mx-auto max-w-6xl px-[var(--page-x)] py-20 sm:py-28">
  <h1 class="text-4xl font-semibold tracking-tight text-on-surface sm:text-5xl lg:text-6xl">
    {heading}
  </h1>
  <p class="mt-6 max-w-2xl text-lg text-on-surface-muted sm:text-xl">
    {tagline}
  </p>
</section>
